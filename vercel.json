{
  "rewrites": [
    { "source": "/((?!assets|favicon|pwa|registerSW|sw\\.js|workbox|robots\\.txt|manifest\\.webmanifest|og-image|apple-touch-icon|placeholder).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
